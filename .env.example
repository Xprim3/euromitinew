# Public site URL (canonical for metadata, robots, sitemap). Set in Vercel → Production.
NEXT_PUBLIC_SITE_URL=https://euromiti.com

# Phase 7 — Supabase anon (never commit real keys — copy from Supabase Dashboard)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key

# Phase 8 — optional on-demand ISR after DB edits (min 8 chars). Call POST /api/revalidate with Authorization: Bearer ...
REVALIDATE_SECRET=
